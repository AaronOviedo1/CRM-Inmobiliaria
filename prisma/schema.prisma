// CRT Administradora CRM — Strata Systems MX
// Modela plazas comerciales, locales, inquilinos, cobranza y finanzas.
// OrgProfile permite escalar hacia COMERCIALIZADORA en el futuro.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// ENUMS
// ============================================================================

enum UserRole {
  ADMINISTRADOR
  ASESOR
}

enum OrgProfile {
  ADMINISTRADORA
  COMERCIALIZADORA
}

enum Entity {
  CRT
  TSR
  QHS
}

enum LocalStatus {
  RENTADO
  DISPONIBLE
  MANTENIMIENTO
  RESERVADO
}

enum PaymentStatus {
  PAGADO
  PENDIENTE
  PARCIAL
  VENCIDO
  NO_APLICA
}

enum MaintenancePriority {
  BAJA
  MEDIA
  ALTA
  URGENTE
}

enum MaintenanceStatus {
  ABIERTO
  EN_PROGRESO
  CERRADO
}

enum ExpenseCategory {
  NOMINA_DIRECCION
  NOMINA_GENERAL
  IMPUESTOS
  HONORARIOS
  MANTENIMIENTO
  SERVICIOS
  VEHICULOS
  SEGUROS
  FINANCIAMIENTOS
  OTROS
}

// ============================================================================
// CORE
// ============================================================================

model Organization {
  id           String     @id @default(cuid())
  name         String
  slug         String     @unique
  phone        String?
  email        String?
  addressLine  String?
  primaryColor String?    @default("#C9A961")
  profile      OrgProfile @default(ADMINISTRADORA)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  users                   User[]
  plazas                  Plaza[]
  locales                 Local[]
  tenants                 Tenant[]
  contracts               Contract[]
  payments                Payment[]
  expenses                Expense[]
  maintenances            Maintenance[]
  budgetLines             BudgetLine[]
  notificationPreferences NotificationPreference[]
}

model User {
  id             String   @id @default(cuid())
  organizationId String
  email          String   @unique
  name           String?
  passwordHash   String?
  role           UserRole @default(ASESOR)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization        Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  passwordResetTokens PasswordResetToken[]

  @@index([organizationId])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model NotificationPreference {
  id             String  @id @default(cuid())
  organizationId String
  userId         String
  channel        String
  enabled        Boolean @default(true)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId, channel])
}

// ============================================================================
// ADMINISTRADORA — PLAZAS & LOCALES
// ============================================================================

model Plaza {
  id             String   @id @default(cuid())
  organizationId String
  entity         Entity   @default(CRT)
  name           String
  code           String
  address        String?
  city           String?  @default("Hermosillo")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  locales      Local[]
  expenses     Expense[]
  budgetLines  BudgetLine[]

  @@unique([organizationId, code])
  @@index([organizationId])
}

model Local {
  id             String      @id @default(cuid())
  organizationId String
  plazaId        String
  code           String
  nickname       String?
  area           Float?
  status         LocalStatus @default(DISPONIBLE)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  plaza        Plaza        @relation(fields: [plazaId], references: [id], onDelete: Cascade)
  contracts    Contract[]
  maintenances Maintenance[]

  @@unique([plazaId, code])
  @@index([organizationId])
  @@index([plazaId])
}

// ============================================================================
// INQUILINOS & CONTRATOS
// ============================================================================

model Tenant {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  legalName      String?
  rfc            String?
  phone          String?
  email          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contracts    Contract[]

  @@index([organizationId])
}

model Contract {
  id             String    @id @default(cuid())
  organizationId String
  localId        String
  tenantId       String
  monthlyRent    Decimal   @db.Decimal(12, 2)
  depositAmount  Decimal?  @db.Decimal(12, 2)
  startDate      DateTime
  endDate        DateTime?
  isActive       Boolean   @default(true)
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  local        Local        @relation(fields: [localId], references: [id])
  tenant       Tenant       @relation(fields: [tenantId], references: [id])
  payments     Payment[]

  @@index([organizationId])
  @@index([localId])
  @@index([tenantId])
}

// ============================================================================
// COBRANZA
// ============================================================================

model Payment {
  id             String        @id @default(cuid())
  organizationId String
  contractId     String
  period         String
  amount         Decimal       @db.Decimal(12, 2)
  status         PaymentStatus @default(PENDIENTE)
  paidAt         DateTime?
  notes          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contract     Contract     @relation(fields: [contractId], references: [id])

  @@unique([contractId, period])
  @@index([organizationId])
  @@index([contractId])
  @@index([period])
}

// ============================================================================
// FINANZAS
// ============================================================================

model BudgetLine {
  id             String  @id @default(cuid())
  organizationId String
  plazaId        String?
  entity         Entity
  year           Int
  month          Int
  label          String
  budgeted       Decimal @db.Decimal(12, 2)
  isIncome       Boolean @default(true)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  plaza        Plaza?       @relation(fields: [plazaId], references: [id])

  @@index([organizationId])
  @@index([entity, year])
}

model Expense {
  id             String          @id @default(cuid())
  organizationId String
  plazaId        String?
  entity         Entity          @default(CRT)
  date           DateTime
  category       ExpenseCategory
  description    String
  amount         Decimal         @db.Decimal(12, 2)
  createdAt      DateTime        @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  plaza        Plaza?       @relation(fields: [plazaId], references: [id])

  @@index([organizationId])
  @@index([entity])
}

// ============================================================================
// MANTENIMIENTOS
// ============================================================================

model Maintenance {
  id             String              @id @default(cuid())
  organizationId String
  localId        String
  reportedAt     DateTime            @default(now())
  description    String
  priority       MaintenancePriority @default(MEDIA)
  status         MaintenanceStatus   @default(ABIERTO)
  resolvedAt     DateTime?
  cost           Decimal?            @db.Decimal(12, 2)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  local        Local        @relation(fields: [localId], references: [id])

  @@index([organizationId])
  @@index([localId])
}
