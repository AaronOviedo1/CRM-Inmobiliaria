// Inmobiliaria CRM — schema multi-tenant completo.
// Toda entidad de negocio lleva organizationId + índice compuesto.
// Soft delete (deletedAt) en modelos críticos. No generamos documentos fiscales ni contratos legales: solo TRACKING.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions", "fullTextSearchPostgres"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pg_trgm]
}

// ============================================================================
// ENUMS
// ============================================================================

