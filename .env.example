# ============================================================================
# INMOBILIARIA CRM — variables de entorno
# ============================================================================
# Copiá este archivo a `.env` y llená los secretos. NUNCA commitees `.env`.

# -- Base de datos ------------------------------------------------------------
DATABASE_URL="postgresql://crm:crm@localhost:5434/inmobiliaria_crm?schema=public"

# -- Auth ---------------------------------------------------------------------
# Genera un secret fuerte: `openssl rand -base64 48`
AUTH_SECRET="change-me-to-a-long-random-string"
AUTH_URL="http://localhost:3000"
# JWT secreto para portales de Owner / Tenant (magic links, 24h TTL)
PORTAL_JWT_SECRET="change-me-separate-from-auth-secret"

# -- Email (Resend) -----------------------------------------------------------
RESEND_API_KEY=""
RESEND_FROM="CRM Inmobiliario <no-reply@tu-dominio.mx>"

# -- WhatsApp Cloud API (Meta) ------------------------------------------------
# Fallback global — cada Organization puede sobreescribir con sus propias creds.
WHATSAPP_APP_ID=""
WHATSAPP_APP_SECRET=""
WHATSAPP_VERIFY_TOKEN=""
WHATSAPP_DEFAULT_PHONE_NUMBER_ID=""
WHATSAPP_DEFAULT_ACCESS_TOKEN=""
# Clave AES-256 (32 bytes base64) para cifrar tokens de WhatsApp por org at-rest.
WHATSAPP_TOKEN_ENCRYPTION_KEY=""

# -- Uploads (UploadThing) ----------------------------------------------------
UPLOADTHING_SECRET=""
UPLOADTHING_APP_ID=""

# -- Mapas y geocoding --------------------------------------------------------
MAPBOX_ACCESS_TOKEN=""
GOOGLE_MAPS_API_KEY=""

# -- Rate limit y colas (Upstash) --------------------------------------------
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# -- Observabilidad -----------------------------------------------------------
SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""

# -- Billing (Stripe) ---------------------------------------------------------
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_STARTER=""
STRIPE_PRICE_PROFESSIONAL=""
STRIPE_PRICE_ENTERPRISE=""

# -- reCAPTCHA (form público) -------------------------------------------------
RECAPTCHA_SECRET_KEY=""
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=""

# -- Cron secret --------------------------------------------------------------
CRON_SECRET="change-me"

# -- Feature flags ------------------------------------------------------------
FEATURE_SMS_BACKUP="false"
FEATURE_WHATSAPP_AUTOPILOT="false"

# -- Timezone -----------------------------------------------------------------
DEFAULT_TIMEZONE="America/Hermosillo"
